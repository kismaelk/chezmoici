rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profilePath(uid) {
      return /databases/$(database)/documents/profiles/$(uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(profilePath(request.auth.uid))
        && get(profilePath(request.auth.uid)).data.is_admin == true;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /profiles/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) || isAdmin();
      allow update, delete: if isOwner(uid) || isAdmin();
    }

    match /annonces/{annonceId} {
      allow read: if resource.data.statut == 'actif'
        || (signedIn() && resource.data.utilisateur_id == request.auth.uid)
        || isAdmin();

      allow create: if signedIn()
        && request.resource.data.utilisateur_id == request.auth.uid;

      allow update, delete: if isAdmin()
        || (signedIn()
          && resource.data.utilisateur_id == request.auth.uid
          && request.resource.data.utilisateur_id == resource.data.utilisateur_id);
    }

    match /favoris/{favoriId} {
      allow read, delete: if signedIn() && resource.data.utilisateur_id == request.auth.uid;
      allow create: if signedIn() && request.resource.data.utilisateur_id == request.auth.uid;
      allow update: if false;
    }

    match /messages/{messageId} {
      allow read: if isAdmin()
        || (signedIn()
          && (resource.data.sender_id == request.auth.uid
            || resource.data.receiver_id == request.auth.uid));

      allow create: if signedIn()
        && request.resource.data.sender_id == request.auth.uid
        && request.resource.data.receiver_id is string
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 4000;

      allow update, delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read, update, delete: if isAdmin()
        || (signedIn() && resource.data.utilisateur_id == request.auth.uid);

      allow create: if signedIn();
    }

    match /avis/{avisId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.auteur_id == request.auth.uid
        && request.resource.data.note is int
        && request.resource.data.note >= 1
        && request.resource.data.note <= 5;
      allow update, delete: if isAdmin();
    }

    match /messages_contact/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /demandes_badge/{id} {
      allow create: if signedIn()
        && request.resource.data.utilisateur_id == request.auth.uid
        && request.resource.data.statut == 'en_attente';

      allow read: if isAdmin()
        || (signedIn() && resource.data.utilisateur_id == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    match /signalements/{id} {
      allow create: if signedIn()
        && request.resource.data.annonce_id is string
        && request.resource.data.annonce_id.size() >= 8
        && request.resource.data.annonce_id.size() <= 128
        && request.resource.data.motif is string
        && request.resource.data.motif.size() >= 3
        && request.resource.data.motif.size() <= 120
        && request.resource.data.signalant_uid == request.auth.uid
        && request.resource.data.statut == 'en_attente'
        && (!('details' in request.resource.data)
          || (request.resource.data.details is string
            && request.resource.data.details.size() <= 2000));

      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
