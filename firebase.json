{
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/outils/credit",
        "destination": "/calculateur-pret/",
        "type": 301
      },
      {
        "source": "/outils",
        "destination": "/calculateur-pret/",
        "type": 301
      }
    ]
  }
}
